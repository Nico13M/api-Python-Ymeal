.env*
lib/
myenv/
__pycache__/
.ipynb_checkpoints/

# Ignore all log files and temp files.
*.log
*.tmp
# Ignore node_modules directory.
node_modules/
# Ignore build output directories.
dist/
build/
# Ignore coverage reports.
coverage/
# Ignore IDE specific files.
.vscode/
.idea/
# Ignore OS generated files.
.DS_Store
Thumbs.db
# Ignore npm debug files.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Ignore lock files (if you want to allow them, remove these lines).
package-lock.json
yarn.lock
# Ignore test output files.
test-output/
# Ignore environment variable files.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Ignore any other files or directories you want to exclude from version control.
